# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Apple MusicKit private keys — never commit
*.p8
AuthKey_*.p8

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# convex
/.convex

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

certificates

*.db

.vscode

# confect source, vendored as a read-only reference for the confect migration
.confect-ref/
# preserved vanilla convex backend, reference during confect migration
.migration-ref/
